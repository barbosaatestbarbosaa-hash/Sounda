end                end
            elseif n:find("hacklord") then
                hackHandle = acc:FindFirstChild("Handle")
            elseif n:find("text_small") then
                textHandle = acc:FindFirstChild("Handle")
            end
        end
    end

    if not iceCubeHandle or #mysteryCubes == 0 or not hackHandle or not textHandle then
        warn("Faltando acessórios necessários")
        return
    end

    -- Config física
    iceCubeHandle:BreakJoints()
    iceCubeHandle.Anchored = true
    iceCubeHandle.CanCollide = false

    for _, cube in ipairs(mysteryCubes) do
        cube:BreakJoints()
        cube.Anchored = true
        cube.CanCollide = false
    end

    hackHandle:BreakJoints()
    hackHandle.Anchored = true
    hackHandle.CanCollide = false

    textHandle:BreakJoints()
    textHandle.Anchored = true
    textHandle.CanCollide = false

    -- Variáveis
    local t = 0
    local direction = 1
    local lastSwitch = tick()

    local iceCF = iceCubeHandle.CFrame
    local hackCF = hackHandle.CFrame
    local mysteryCFs = {}
    for _, cube in ipairs(mysteryCubes) do
        table.insert(mysteryCFs, cube.CFrame)
    end

    local backshotCount = 0
    local lastEventTime = 0

    local flingActive = false
    local flingTarget = nil
    local flingStart = 0
    local slowApproachEnd = 0
    local returning = false
    local returnStart = 0

    local connection
    connection = RunService.Heartbeat:Connect(function(dt)
        if not character.Parent or not iceCubeHandle.Parent then
            if connection then connection:Disconnect() end
            return
        end

        t = t + dt

        if t - lastSwitch >= SWITCH_TIME then
            direction = -direction
            lastSwitch = t
        end

        -- Posição Ice Cube (centro)
        local basePos = rootPart.Position + rootPart.CFrame.RightVector * 5 + Vector3.new(0, 2, 0)
        local float = math.sin(t * 2) * 0.8
        local icePos = basePos + Vector3.new(0, float, 0)

        local rx = math.sin(t * 1.5) * 1.5
        local ry = math.sin(t * 1.2) * 2
        local rz = math.sin(t * 1.8) * 1.3

        local targetIceNormal = CFrame.new(icePos) * CFrame.Angles(rx, ry, rz)

        -- Nearest player
        local nearestPlayer, nearestDist = nil, 16
        for _, plr in Players:GetPlayers() do
            if plr \~= player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                local dist = (plr.Character.HumanoidRootPart.Position - icePos).Magnitude
                if dist < nearestDist then
                    nearestDist = dist
                    nearestPlayer = plr
                end
            end
        end

        -- Text Small
        if nearestPlayer then
            local tgt = nearestPlayer.Character.HumanoidRootPart.Position
            textHandle.CFrame = CFrame.new(icePos + Vector3.new(0, 1.5, 0), tgt)
        else
            textHandle.CFrame = CFrame.new(icePos + Vector3.new(0, -25, 0))
        end

        -- Modo normal (não fling)
        if not flingActive and not returning then
            iceCF = iceCF:Lerp(targetIceNormal, 0.15)
            iceCubeHandle.CFrame = iceCF

            -- Hacklord gira dentro
            local hackAngle = t * HACKLORD_SPIN_SPEED * direction
            local hackOffset = Vector3.new(math.cos(hackAngle) * HACKLORD_INNER_RADIUS, math.sin(hackAngle * 1.5) * 0.6, math.sin(hackAngle) * HACKLORD_INNER_RADIUS)
            local hackTargetPos = icePos + hackOffset
            local targetHackCF = CFrame.new(hackTargetPos) * CFrame.Angles(0, t * 8, 0)
            hackCF = hackCF:Lerp(targetHackCF, 0.25)
            hackHandle.CFrame = hackCF

            -- Mystery Cubes orbitam
            for i, cube in ipairs(mysteryCubes) do
                local phase = (i - 1) * (math.pi * 2 / math.max(#mysteryCubes, 1))
                local angle = t * ORBIT_SPEED_BASE * direction + phase

                local heightOsc = 0
                if #mysteryCubes >= 2 and i == 2 then heightOsc = math.sin(angle * 1.8) * 2.5 end
                if #mysteryCubes >= 3 and i == 3 then heightOsc = math.sin(t * 1.4 + phase) * 3.5 end

                local offset = Vector3.new(math.cos(angle) * ORBIT_RADIUS, heightOsc + math.sin(t * 3 + phase) * 0.4, math.sin(angle) * ORBIT_RADIUS)

                local targetPos = icePos + offset
                local targetCF = CFrame.new(targetPos) * CFrame.Angles(t * SPIN_SPEED * 0.6, t * SPIN_SPEED * direction, t * SPIN_SPEED * 0.4)

                mysteryCFs[i] = mysteryCFs[i]:Lerp(targetCF, 0.18)
                cube.CFrame = mysteryCFs[i]
            end
        end

        -- Backshot detection
        if nearestPlayer then
            local otherRoot = nearestPlayer.Character.HumanoidRootPart
            local toOther = (otherRoot.Position - rootPart.Position).Unit
            local forward = rootPart.CFrame.LookVector
            local dot = toOther:Dot(forward)

            local isClose = (otherRoot.Position - rootPart.Position).Magnitude < 8
            local isAttempt = (dot < -0.65 or dot > 0.65) and isClose

            if isAttempt and tick() - lastEventTime > 0.7 then
                backshotCount = backshotCount + 1
                lastEventTime = tick()

                if backshotCount >= BACKSHOT_THRESHOLD then
                    flingActive = true
                    flingTarget = otherRoot
                    flingStart = tick()
                    slowApproachEnd = tick() + SLOW_APPROACH_TIME
                    backshotCount = 0
                end
            end
        else
            backshotCount = 0
        end

        -- Fling: reação com o cubo inteiro (Hacklord lidera)
        if flingActive then
            local dur = tick() - flingStart
            if dur > FLING_DURATION then
                flingActive = false
                returning = true
                returnStart = tick()
                flingTarget = nil
            else
                local targetPos = flingTarget.Position + Vector3.new(0, 2.5, 0)
                local dirToTarget = (targetPos - hackHandle.Position).Unit

                local isSlowPhase = tick() < slowApproachEnd
                local currentSpeed = isSlowPhase and SLOW_SPEED or FAST_SPEED
                local moveDelta = dirToTarget * currentSpeed * dt

                -- Hacklord: vira + move (devagar → rápido)
                local lookAtCF = CFrame.new(hackHandle.Position, targetPos) * CFrame.Angles(0, math.rad(180), 0)
                local lerpAlpha = isSlowPhase and 0.12 or 0.5
                hackCF = hackCF:Lerp(lookAtCF + moveDelta, lerpAlpha)

                -- Spin louco na fase rápida
                if not isSlowPhase then
                    hackCF = hackCF * CFrame.Angles(t*45, t*60, t*40)
                end
                hackHandle.CFrame = hackCF

                -- Ice Cube e Mystery Cubes acompanham o Hacklord (cubo inteiro reage junto)
                local groupDir = (targetPos - icePos).Unit * (isSlowPhase and 12 or 45) * dt

                iceCF = iceCF:Lerp(CFrame.new(iceCubeHandle.Position + groupDir) * CFrame.Angles(t*30, t*45, t*25), 0.4)
                iceCubeHandle.CFrame = iceCF

                for i, cube in ipairs(mysteryCubes) do
                    local chaos = Vector3.new(math.sin(t*35)*1.8, math.cos(t*28)*1.8, math.sin(t*42)*1.8)
                    mysteryCFs[i] = mysteryCFs[i]:Lerp(CFrame.new(cube.Position + groupDir + chaos) * CFrame.Angles(t*35, t*50, t*30), 0.45)
                    cube.CFrame = mysteryCFs[i]
                end

                -- Fling velocity (mais forte na rápida)
                if flingTarget and flingTarget.Parent then
                    local force = isSlowPhase and 50 or 150
                    flingTarget.AssemblyLinearVelocity = dirToTarget * force + Vector3.new(0, 70, 0)
                end
            end
        end

        -- Retorno suave
        if returning then
            local returnDur = tick() - returnStart
            local returnAlpha = math.min(returnDur / 1.5, 1)

            local targetIce = CFrame.new(icePos) * CFrame.Angles(rx, ry, rz)
            iceCF = iceCF:Lerp(targetIce, returnAlpha * 0.4)
            iceCubeHandle.CFrame = iceCF

            local hackAngle = t * HACKLORD_SPIN_SPEED * direction
            local hackOffset = Vector3.new(math.cos(hackAngle) * HACKLORD_INNER_RADIUS, math.sin(hackAngle * 1.5) * 0.6, math.sin(hackAngle) * HACKLORD_INNER_RADIUS)
            local hackTargetPos = icePos + hackOffset
            hackCF = hackCF:Lerp(CFrame.new(hackTargetPos) * CFrame.Angles(0, t * 8, 0), returnAlpha * 0.4)
            hackHandle.CFrame = hackCF

            for i, cube in ipairs(mysteryCubes) do
                local phase = (i - 1) * (math.pi * 2 / math.max(#mysteryCubes, 1))
                local angle = t * ORBIT_SPEED_BASE * direction + phase

                local heightOsc = 0
                if #mysteryCubes >= 2 and i == 2 then heightOsc = math.sin(angle * 1.8) * 2.5 end
                if #mysteryCubes >= 3 and i == 3 then heightOsc = math.sin(t * 1.4 + phase) * 3.5 end

                local offset = Vector3.new(math.cos(angle) * ORBIT_RADIUS, heightOsc + math.sin(t * 3 + phase) * 0.4, math.sin(angle) * ORBIT_RADIUS)

                local targetPos = icePos + offset
                local targetCF = CFrame.new(targetPos) * CFrame.Angles(t * SPIN_SPEED * 0.6, t * SPIN_SPEED * direction, t * SPIN_SPEED * 0.4)

                mysteryCFs[i] = mysteryCFs[i]:Lerp(targetCF, returnAlpha * 0.4)
                cube.CFrame = mysteryCFs[i]
            end

            if returnAlpha >= 1 then returning = false end
        end
    end)

    humanoid.Died:Connect(function()
        if connection then connection:Disconnect() end
    end)
end

